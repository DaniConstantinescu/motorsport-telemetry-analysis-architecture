# Toggle the artificial RabbitMQ latency hop used by edge_server.
#
# Enabled:
# EDGE_RABBITMQ_HOST=rabbitmq_latency_proxy
#
# Disabled:
# EDGE_RABBITMQ_HOST=rabbitmq
EDGE_RABBITMQ_HOST=rabbitmq_latency_proxy

# One-way latency and jitter in milliseconds for the England-Japan proxy.
ENGLAND_JAPAN_LATENCY_MS=250
ENGLAND_JAPAN_JITTER_MS=35
